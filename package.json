{
  "name": "@project-river/root",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @project-river/web dev",
    "build": "pnpm -r build",
    "serve:pages": "pnpm --filter @project-river/web generate:gh && pnpm --filter @project-river/web preview:gh",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "prepare": "husky",
    "db:migrate": "pnpm --filter @project-river/db db:migrate",
    "test": "vitest run"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,vue,json,md}": "eslint --fix"
  }
}
